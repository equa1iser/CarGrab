# Database
POSTGRES_PASSWORD=secret
DATABASE_URL=postgresql+asyncpg://cargrab:secret@postgres:5432/cargrab

# Redis
REDIS_URL=redis://redis:6379/0

# JWT
JWT_SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:3000

# Data source API keys (leave blank to disable that source gracefully)
MARKETCHECK_API_KEY=
CARVANA_API_KEY=

# Auto.dev — free tier: 1,000 calls/month — https://auto.dev
AUTODEV_API_KEY=

# eBay Motors — free developer account — https://developer.ebay.com
EBAY_APP_ID=
EBAY_CERT_ID=

# NHTSA (free, no key needed)
NHTSA_API_BASE=https://vpic.nhtsa.dot.gov/api
NHTSA_RECALLS_BASE=https://api.nhtsa.gov/recalls

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXTAUTH_SECRET=change-me-in-production
NEXTAUTH_URL=http://localhost:3000

# Optional: Sentry error tracking
SENTRY_DSN=
