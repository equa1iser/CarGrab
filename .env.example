# Database
POSTGRES_PASSWORD=secret
DATABASE_URL=postgresql+asyncpg://cargrab:secret@postgres:5432/cargrab

# Redis
REDIS_URL=redis://redis:6379/0

# JWT
JWT_SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:3000

# Data source API keys (leave blank to disable that source gracefully)
MARKETCHECK_API_KEY=
CARVANA_API_KEY=

# Auto.dev — free tier: 1,000 calls/month — https://auto.dev
AUTODEV_API_KEY=

# eBay Motors — free developer account — https://developer.ebay.com
EBAY_APP_ID=
EBAY_CERT_ID=

# NHTSA (free, no key needed)
NHTSA_API_BASE=https://vpic.nhtsa.dot.gov/api
NHTSA_RECALLS_BASE=https://api.nhtsa.gov/recalls

# Google OAuth (create credentials at https://console.cloud.google.com)
# Add http://localhost:3000 as an Authorized JavaScript Origin
GOOGLE_CLIENT_ID=
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# SMTP (for password reset emails — leave blank in dev, reset links appear in docker logs)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@cargrab.com
APP_URL=http://localhost:3000

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000

# Optional: Sentry error tracking
SENTRY_DSN=

# Admin (JSON array of emails with admin access to /admin page)
ADMIN_EMAILS=["you@example.com"]
